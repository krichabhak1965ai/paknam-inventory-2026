function doGet(e) {
  var template = HtmlService.createTemplateFromFile('Index');
  var output = template.evaluate();
  output.setTitle("ระบบบริหารจัดการสินค้าในคลัง (Paknam Inventory 2026)")
        .addMetaTag('viewport', 'width=device-width, initial-scale=1.0')
        .setXFrameOptionsMode(HtmlService.XFrameOptionsMode.ALLOWALL);
  return output;
}

function forceAuthorize() {
  try {
    var root = DriveApp.getRootFolder();
    var name = root.getName();
    var activeSS = SpreadsheetApp.getActiveSpreadsheet();
    Logger.log("Authorized successfully. Root folder: " + name + ", Sheet ID: " + activeSS.getId());
    return { success: true, message: "เชื่อมโยงสิทธิ์การใช้งานสำเร็จแล้ว!" };
  } catch (error) {
    Logger.log("Auth error: " + error.toString());
    return { success: false, message: "เกิดข้อผิดพลาดในการขอสิทธิ์: " + error.toString() };
  }
}

