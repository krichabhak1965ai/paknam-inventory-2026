function createTransaction(txData) {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var prodSheet = ss.getSheetByName("Products");
  var txSheet = ss.getSheetByName("Transactions");
  
  if (!prodSheet || !txSheet) {
    return { success: false, message: "ตาราง Products หรือ Transactions หายไปจากระบบ" };
  }
  
  var prodValues = prodSheet.getDataRange().getValues();
  var prodHeaders = prodValues[0];
  var prodIdIdx = prodHeaders.indexOf("id");
  var prodStockIdx = prodHeaders.indexOf("stock");
  
  var targetProdId = txData.productId;
  var txType = txData.type;
  var txQty = Number(txData.qty);
  
  if (isNaN(txQty) || txQty <= 0) {
    return { success: false, message: "กรุณาระบุจำนวนสินค้าที่ถูกต้อง" };
  }
  
  var productRowIndex = -1;
  var currentStock = 0;
  for (var i = 1; i < prodValues.length; i++) {
    if (prodValues[i][prodIdIdx] === targetProdId) {
      productRowIndex = i + 1;
      currentStock = Number(prodValues[i][prodStockIdx]);
      break;
    }
  }
  if (productRowIndex === -1) {
    return { success: false, message: "ไม่พบสินค้าในสารบบ" };
  }
  
  var updatedStock = currentStock;
  if (txType === "IN") {
    updatedStock = currentStock + txQty;
  } else if (txType === "OUT" || txType === "DEFECT") {
    if (currentStock < txQty) {
      return { success: false, message: "สินค้าไม่เพียงพอเบิก (คงเหลือ " + currentStock + " ชิ้น)" };
    }
    updatedStock = currentStock - txQty;
  } else if (txType === "RETURN") {
    if (txData.condition === "สมบูรณ์") {
      updatedStock = currentStock + txQty;
    }
  }
  
  var warningMsg = null;
  var imgUrl = "";
  if (txData.imageBase64) {
    var uploadResult = uploadImageToDrive(txData.imageBase64, "TX_" + txType + "_" + Date.now() + ".jpg");
    if (uploadResult.warning) {
      warningMsg = uploadResult.warning;
    }
    if (uploadResult.url) {
      imgUrl = uploadResult.url;
    }
  }
  
  var txId = "TX" + Utilities.formatDate(new Date(), "GMT+7", "yyyyMMdd-HHmmss") + "-" + Math.floor(Math.random() * 1000);
  var txDateStr = Utilities.formatDate(new Date(), "GMT+7", "yyyy-MM-dd HH:mm:ss");
  
  var txRow = [
    txId,
    txType,
    targetProdId,
    txQty,
    txDateStr,
    txData.note || "",
    txData.user || "System",
    txData.status || "Completed",
    txData.defectType || "",
    txData.condition || "",
    imgUrl
  ];
  
  txSheet.appendRow(txRow);
  prodSheet.getRange(productRowIndex, prodStockIdx + 1).setValue(updatedStock);
  
  return { 
    success: true, 
    message: "บันทึกและอัปเดตสต๊อกสินค้าเรียบร้อยแล้ว", 
    txId: txId, 
    updatedStock: updatedStock,
    warning: warningMsg 
  };
}
