    };
  });
}

function saveProduct(productData) {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var sheet = ss.getSheetByName("Products");
  if (!sheet) return { success: false, message: "ไม่พบตาราง Products" };
  
  var values = sheet.getDataRange().getValues();
  var headers = values[0];
  var idColIdx = headers.indexOf("id");
  
  var prodId = productData.id;
  var isNew = !prodId;
  var warningMsg = null;
  
  var imgUrl = productData.imageUrl;
  if (productData.imageBase64) {
    var uploadResult = uploadImageToDrive(productData.imageBase64, (productData.code || "PROD") + "_" + Date.now() + ".jpg");
    if (uploadResult.warning) {
      warningMsg = uploadResult.warning;
    }
    if (uploadResult.url) {
      imgUrl = uploadResult.url;
    }
  }
  
  if (isNew) {
    prodId = "P" + Utilities.formatDate(new Date(), "GMT+7", "yyyyMMdd-HHmmss") + "-" + Math.floor(Math.random() * 1000);
  }
  
  var rowData = [
    prodId,
    String(productData.code).trim(),
    String(productData.name).trim(),
    String(productData.category).trim(),
    Number(productData.stock || 0),
    Number(productData.min || 0),
    imgUrl || ""
  ];
  
  if (isNew) {
    for (var i = 1; i < values.length; i++) {
      if (String(values[i][1]).trim() === String(productData.code).trim()) {
        return { success: false, message: "รหัสสินค้า '" + productData.code + "' มีอยู่แล้วในคลัง" };
      }
    }
    sheet.appendRow(rowData);
    return { success: true, message: "เพิ่มข้อมูลสินค้าใหม่สำเร็จแล้ว", id: prodId, warning: warningMsg };
  } else {
    for (var i = 1; i < values.length; i++) {
      if (values[i][idColIdx] === prodId) {
        for (var j = 1; j < values.length; j++) {
          if (j !== i && String(values[j][1]).trim() === String(productData.code).trim()) {
            return { success: false, message: "รหัสสินค้า '" + productData.code + "' มีอยู่แล้วในระบบ" };
          }
        }
        sheet.getRange(i + 1, 1, 1, rowData.length).setValues([rowData]);
        return { success: true, message: "อัปเดตข้อมูลสินค้าสำเร็จแล้ว", id: prodId, warning: warningMsg };
      }
    }
  }
  return { success: false, message: "ไม่พบสินค้าที่ต้องการบันทึก" };
}

function deleteProduct(productId) {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var sheet = ss.getSheetByName("Products");
  if (!sheet) return { success: false, message: "ไม่พบตาราง Products" };
  
  var values = sheet.getDataRange().getValues();
  for (var i = 1; i < values.length; i++) {
    if (values[i][0] === productId) {
      sheet.deleteRow(i + 1);
      return { success: true, message: "ลบสินค้าสำเร็จเรียบร้อยแล้ว" };
    }
  }
  return { success: false, message: "ไม่พบสินค้าคลังสินค้าที่เลือก" };
}

