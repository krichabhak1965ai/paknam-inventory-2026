function sheetToObjects(sheetName) {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var sheet = ss.getSheetByName(sheetName);
  if (!sheet) return [];
  
  var data = sheet.getDataRange().getValues();
  if (data.length <= 1) return [];
  
  var headers = data[0];
  var rows = data.slice(1);
  
  return rows.map(function(row) {
    var obj = {};
    headers.forEach(function(header, idx) {
      obj[header] = row[idx];
    });
    return obj;
  });
}

function authenticateUser(username, password) {
  var targetUsername = String(username).trim();
  var targetPassword = String(password).trim();
  
  var users = sheetToObjects("Users");
  for (var i = 0; i < users.length; i++) {
    var dbUser = users[i];
    if (String(dbUser.username).trim() === targetUsername && String(dbUser.password).trim() === targetPassword) {
      return {
        id: dbUser.id,
        username: dbUser.username,
        name: dbUser.name,
        role: dbUser.role
      };
    }
  }
  return null;
}

function getStoreSettings() {
  var settingsList = sheetToObjects("Settings");
  var settingsObj = {};
  settingsList.forEach(function(item) {
    settingsObj[item.key] = item.value;
  });
  return settingsObj;
}

function saveStoreSettings(settingsData) {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var sheet = ss.getSheetByName("Settings");
  if (!sheet) return { success: false, message: "ไม่พบตาราง Settings" };
  
  var dataRange = sheet.getDataRange();
  var values = dataRange.getValues();
  
  for (var key in settingsData) {
    var value = settingsData[key];
    var found = false;
    for (var i = 1; i < values.length; i++) {
      if (values[i][0] === key) {
        sheet.getRange(i + 1, 2).setValue(value);
        found = true;
        break;
      }
    }
    if (!found) {
      sheet.appendRow([key, value]);
    }
  }
  return { success: true, message: "บันทึกข้อมูลการตั้งค่าสำเร็จแล้ว" };
}

function getUsers() {
  return sheetToObjects("Users").map(function(user) {
    return {
      id: user.id,
      username: user.username,
      password: user.password,
      name: user.name,
      role: user.role
    };
  });
}

function saveUser(userData) {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var sheet = ss.getSheetByName("Users");
  if (!sheet) return { success: false, message: "ไม่พบตาราง Users" };
  
  var values = sheet.getDataRange().getValues();
  var headers = values[0];
  var idColIdx = headers.indexOf("id");
  
  var userId = userData.id;
  var isNew = !userId;
  
  if (isNew) {
    userId = "U" + Utilities.formatDate(new Date(), "GMT+7", "yyyyMMdd-HHmmss") + "-" + Math.floor(Math.random() * 1000);
  }
  
  var rowData = [
    userId,
    String(userData.username).trim(),
    String(userData.password).trim(),
    userData.name,
    userData.role
  ];
  
  if (isNew) {
    sheet.appendRow(rowData);
    return { success: true, message: "เพิ่มพนักงานใหม่สำเร็จ" };
  } else {
    for (var i = 1; i < values.length; i++) {
      if (values[i][idColIdx] === userId) {
        sheet.getRange(i + 1, 1, 1, rowData.length).setValues([rowData]);
        return { success: true, message: "แก้ไขข้อมูลพนักงานสำเร็จ" };
      }
    }
  }
  return { success: false, message: "ไม่พบข้อมูลพนักงานที่ต้องการแก้ไข" };
}

function deleteUser(userId) {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var sheet = ss.getSheetByName("Users");
  if (!sheet) return { success: false, message: "ไม่พบตาราง Users" };
  
  var values = sheet.getDataRange().getValues();
  for (var i = 1; i < values.length; i++) {
    if (values[i][0] === userId) {
      if (values[i][1] === "admin") {
        return { success: false, message: "ไม่สามารถลบผู้ใช้งาน Admin หลักระบบได้" };
      }
      sheet.deleteRow(i + 1);
      return { success: true, message: "ลบผู้ใช้งานเรียบร้อยแล้ว" };
    }
  }
  return { success: false, message: "ไม่พบผู้ใช้งานที่ระบุ" };
}

function uploadImageToDrive(base64Data, fileName) {
  if (!base64Data) return { success: true, url: "", warning: null };
  try {
    var folderName = "Paknam_Inventory_Images";
    var folders = DriveApp.getFoldersByName(folderName);
    var folder;
    if (folders.hasNext()) {
      folder = folders.next();
    } else {
      folder = DriveApp.createFolder(folderName);
      try {
        folder.setSharing(DriveApp.Access.ANYONE_WITH_LINK, DriveApp.Permission.VIEW);
      } catch (shareErr) {
        Logger.log("Could not set folder sharing options: " + shareErr.toString());
      }
    }
    
    var parts = base64Data.split(",");
    var contentType = "image/jpeg";
    var b64Content = parts[0];
    if (parts.length > 1) {
      contentType = parts[0].split(";")[0].split(":")[1];
      b64Content = parts[1];
    }
    
    var decoded = Utilities.base64Decode(b64Content);
    var blob = Utilities.newBlob(decoded, contentType, fileName || "upload_image.jpg");
    var file = folder.createFile(blob);
    
    try {
      file.setSharing(DriveApp.Access.ANYONE_WITH_LINK, DriveApp.Permission.VIEW);
    } catch (shareErr) {
      Logger.log("Could not set file sharing options: " + shareErr.toString());
    }
    
    var fileId = file.getId();
    var imageUrl = "https://lh3.googleusercontent.com/d/" + fileId;
    return { success: true, url: imageUrl, warning: null };
  } catch (error) {
    Logger.log("Upload failed: " + error.toString());
    return {
      success: false,
      url: "",
      warning: "ไม่สามารถอัปโหลดรูปภาพลง Google Drive ได้ชั่วคราว (เนื่องจากข้อจำกัดด้านสิทธิ์ของบัญชี): " + error.toString()
    };
  }
}

